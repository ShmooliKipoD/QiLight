{
  "version": "2.0.0",
  "options": {
    "env": {
      "DYLD_FALLBACK_LIBRARY_PATH": "/opt/homebrew/lib"
    }
  },
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/src/QiLight.Game/QiLight.Game.csproj"],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "run",
      "command": "dotnet",
      "type": "process",
      "args": ["run", "--project", "${workspaceFolder}/src/QiLight.Game/QiLight.Game.csproj"],
      "dependsOn": "build",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
